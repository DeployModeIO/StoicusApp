<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF0B1D2A"
                android:centerColor="#FF102A3E"
                android:endColor="#FF06121C"
                android:angle="180" />
        </shape>
    </item>
    <item>
        <vector xmlns:android="http://schemas.android.com/apk/res/android"
            android:width="400dp" android:height="800dp"
            android:viewportWidth="400" android:viewportHeight="800">
            <!-- Columna 1 -->
            <path android:fillColor="#143D4A4A"
                android:pathData="M40,800 L40,200 L60,180 L120,180 L140,200 L140,800 Z" />
            <path android:fillColor="#0A2A3434"
                android:pathData="M30,200 L150,200 L150,180 L30,180 Z" />
            <path android:fillColor="#0A2A3434"
                android:pathData="M30,800 L150,800 L150,780 L30,780 Z" />
            <!-- Estrías columna 1 -->
            <path android:strokeColor="#08444444" android:strokeWidth="1"
                android:pathData="M50,200 L50,780 M65,200 L65,780 M80,200 L80,780 M95,200 L95,780 M110,200 L110,780 M125,200 L125,780" />
            <!-- Columna 2 -->
            <path android:fillColor="#12394747"
                android:pathData="M180,800 L180,220 L200,200 L260,200 L280,220 L280,800 Z" />
            <path android:fillColor="#0A2A3434"
                android:pathData="M170,220 L290,220 L290,200 L170,200 Z" />
            <path android:fillColor="#0A2A3434"
                android:pathData="M170,800 L290,800 L290,780 L170,780 Z" />
            <!-- Columna 3 (parcial) -->
            <path android:fillColor="#102F3838"
                android:pathData="M320,800 L320,240 L340,220 L400,220 L400,800 Z" />
            <!-- Sol/luna detrás -->
            <path android:fillColor="#15D4AF37"
                android:pathData="M200,120 m-60,0 a60,60 0 1,0 120,0 a60,60 0 1,0 -120,0" />
        </vector>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:type="radial"
                android:startColor="#18D4AF37"
                android:endColor="#00000000"
                android:gradientRadius="300dp" />
            <size android:width="400dp" android:height="400dp" />
        </shape>
    </item>
</layer-list>